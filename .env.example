# DataSwarm local runtime
DATASWARM_DATA_DIR=../../data
DATASWARM_WORKSPACE_ROOT=../..

# Use mock streaming for local M1 development without provider keys.
DATASWARM_MOCK_MODEL=1

# DMXAPI OpenAI-compatible provider.
DMX_BASE_URL=https://www.dmxapi.cn/v1
DMX_API_KEY=

# DeepSeek sandbox provider, used from M3 onward.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

# Sandbox and web research providers.
DATASWARM_SANDBOX_PROVIDER=mock
E2B_API_KEY=
TAVILY_API_KEY=
